{
  "name": "rolling-context",
  "version": "1.0.0",
  "description": "Rolling context compression — old messages get summarized, recent messages stay verbatim. Never hit the context wall.",
  "author": {
    "name": "NodeNestor"
  },
  "homepage": "https://github.com/NodeNestor/claude-rolling-context",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -ExecutionPolicy Bypass -File \"$CLAUDE_PLUGIN_DIR/../hooks/on-session-start.ps1\" 2>/dev/null || bash \"$CLAUDE_PLUGIN_DIR/../hooks/on-session-start.sh\" 2>/dev/null",
            "timeout": 15000
          }
        ]
      }
    ]
  }
}
